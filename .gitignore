# =============================================================================
# .gitignore для UI-for-ytdlp
# =============================================================================

# -----------------------------------------------------------------------------
# IDE и редакторы
# -----------------------------------------------------------------------------
/.idea/
/.vscode/
/*.swp
/*.swo
*~
*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
*.egg
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.manifest
*.spec.bak

# Виртуальное окружение
venv/
ENV/
env/
.venv/

# -----------------------------------------------------------------------------
# PyInstaller
# -----------------------------------------------------------------------------
build/
dist/
*.spec.bak

# -----------------------------------------------------------------------------
# Конфигурация приложения
# -----------------------------------------------------------------------------
utilities/config.json
utilities/config.json.bkp

# -----------------------------------------------------------------------------
# Логи и временные файлы
# -----------------------------------------------------------------------------
*.log
logs/
tmp/
temp/
*.tmp

# -----------------------------------------------------------------------------
# Тестовые загрузки и частичные файлы
# -----------------------------------------------------------------------------
test_downloads/
*.part

# -----------------------------------------------------------------------------
# Утилиты (скачанные файлы — yt-dlp, ffmpeg и др.)
# Сторонние бинарники НЕ храним в git; загружаются при первом запуске.
# Игнорируем ВСЁ в utilities/ кроме .gitkeep
# -----------------------------------------------------------------------------
/utilities/*
!/utilities/.gitkeep
utilities/yt-dlp.exe
utilities/ffmpeg.exe
utilities/ffplay.exe
utilities/ffprobe.exe
utilities/*.zip

# -----------------------------------------------------------------------------
# Загруженные видео (игнорируем в корне проекта)
# -----------------------------------------------------------------------------
/*.mp4
/*.webm
/*.mkv
/*.avi
/*.mov
/*.flv
/*.wmv

# -----------------------------------------------------------------------------
# macOS
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*

# -----------------------------------------------------------------------------
# Windows
# -----------------------------------------------------------------------------
Thumbs.db
desktop.ini
ehthumbs.db
Icon
$RECYCLE.BIN/
System Volume Information/

# -----------------------------------------------------------------------------
# Среда разработки
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.local
.pytest_cache/
.coverage
htmlcov/
.pytest/
.mypy_cache/
.ruff_cache/
.tox/
.nox/

# -----------------------------------------------------------------------------
# Документация
# -----------------------------------------------------------------------------
docs/_build/
docs/.doctrees/

# -----------------------------------------------------------------------------
# Jupyter Notebook
# -----------------------------------------------------------------------------
.ipynb_checkpoints/

# -----------------------------------------------------------------------------
# pyenv
# -----------------------------------------------------------------------------
.python-version

# -----------------------------------------------------------------------------
# Celery
# -----------------------------------------------------------------------------
celerybeat-schedule
celerybeat.pid

# -----------------------------------------------------------------------------
# SageMath
# -----------------------------------------------------------------------------
*.sage.py

# -----------------------------------------------------------------------------
# Spyder
# -----------------------------------------------------------------------------
.spyderproject
.spyproject

# -----------------------------------------------------------------------------
# Rope
# -----------------------------------------------------------------------------
.ropeproject

# -----------------------------------------------------------------------------
# mkdocs
# -----------------------------------------------------------------------------
/site

# -----------------------------------------------------------------------------
# mypy
# -----------------------------------------------------------------------------
/.mypy_cache/
.dmypy.json
dmypy.json

# -----------------------------------------------------------------------------
# Pyre
# -----------------------------------------------------------------------------
.pyre/

# -----------------------------------------------------------------------------
# VS Code
# -----------------------------------------------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
